#!/usr/bin/env python3
"""
Aether — Wireless Android Mirror
"""

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")

from gi.repository import Gtk, Adw, GLib, Gio, Gdk
import json, subprocess, threading, re
from pathlib import Path

CONFIG_DIR  = Path.home() / ".config" / "aether"
CONFIG_FILE = CONFIG_DIR / "devices.json"

DEFAULT_SETTINGS = {
    "resolution":      1080,
    "max_fps":         60,
    "bitrate":         "16M",
    "codec":           "h264",
    "turn_off_screen": True,
    "stay_awake":      True,
}

def load_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except Exception:
            pass
    return {"devices": []}

def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

def run(*args, inp=None, timeout=10):
    try:
        r = subprocess.run(list(args), capture_output=True, text=True,
                           timeout=timeout, input=inp)
        return r.stdout.strip(), r.stderr.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", "timeout", 1
    except FileNotFoundError:
        return "", f"{args[0]} not found", 1

def adb(*args, **kw):
    return run("adb", *args, **kw)

def adb_start():
    adb("start-server")

def adb_connect(ip_port, timeout=8):
    out, _, _ = adb("connect", ip_port, timeout=timeout)
    return "connected" in out.lower() or "already" in out.lower()

def adb_disconnect(ip_port):
    adb("disconnect", ip_port)

def adb_pair(ip_port, code, timeout=20):
    try:
        r = subprocess.run(["adb", "pair", ip_port],
                           input=code + "\n",
                           capture_output=True, text=True, timeout=timeout)
        return "successfully" in r.stdout.lower() or r.returncode == 0
    except Exception:
        return False

def adb_connected_serials():
    out, _, _ = adb("devices")
    return [l.split()[0] for l in out.splitlines()[1:]
            if len(l.split()) >= 2 and l.split()[1] == "device"]

def get_current_ssid():
    try:
        r = subprocess.run(["nmcli", "-t", "-f", "active,ssid", "dev", "wifi"],
                           capture_output=True, text=True, timeout=5)
        for line in r.stdout.splitlines():
            if line.startswith("yes:"):
                return line.split(":", 1)[1].strip()
    except Exception:
        pass
    return None

def build_scrcpy_args(settings):
    s = {**DEFAULT_SETTINGS, **settings}
    args = [
        "--video-bit-rate", s["bitrate"],
        "--max-fps", str(s["max_fps"]),
        "--max-size", str(s["resolution"]),
        "--video-buffer=0",
        "--video-codec", s["codec"],
        "--capture-orientation=0",
    ]
    if s["turn_off_screen"]:
        args.append("--turn-screen-off")
    if s["stay_awake"]:
        args.append("--stay-awake")
    return args

