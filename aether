CONFIG_DIR  = Path.home() / ".config" / "aether"
CONFIG_FILE = CONFIG_DIR / "devices.json"
_SCRIPT_DIR = Path(__file__).resolve().parent   # may be ~/.local/bin when installed

def _find_aether_dir():
    """Return the AETHER project folder containing ae.png / phone.png.
    When the script is run from ~/.local/bin the script dir won't have the
    assets, so we also check ~/AETHER and the directory of the real file."""
    candidates = [
        _SCRIPT_DIR,
        Path.home() / "AETHER",
        Path.home() / ".local" / "share" / "aether",
    ]
    for p in candidates:
        if (p / "phone.png").exists():
            return p
    return _SCRIPT_DIR   # fallback (assets may simply be missing)

AETHER_DIR = _find_aether_dir()

DEFAULT_SETTINGS = {
    "resolution":      1080,
    "max_fps":         60,
    "bitrate":         "16M",
    "codec":           "h264",
    "turn_off_screen": True,
    "stay_awake":      True,
}

def load_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except Exception:
            pass
    return {"devices": []}

def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

def run(*args, inp=None, timeout=10):
    try:
        r = subprocess.run(list(args), capture_output=True, text=True,
                           timeout=timeout, input=inp)
        return r.stdout.strip(), r.stderr.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", "timeout", 1
    except FileNotFoundError:
        return "", f"{args[0]} not found", 1

def adb(*args, **kw):
    return run("adb", *args, **kw)

def adb_start():
    adb("start-server")

def adb_connect(ip_port, timeout=8):
    out, err, _ = adb("connect", ip_port, timeout=timeout)
    combined = (out + " " + err).lower()
    return "connected" in combined or "already" in combined

def adb_disconnect(ip_port):
    adb("disconnect", ip_port)

def adb_pair(ip_port, code, timeout=20):
    try:
        r = subprocess.run(["adb", "pair", ip_port],
                           input=code + "\n",
                           capture_output=True, text=True, timeout=timeout)
        return "successfully" in r.stdout.lower() or r.returncode == 0
    except Exception:
        return False

def adb_connected_serials():
    out, _, _ = adb("devices")
    return [l.split()[0] for l in out.splitlines()[1:]
            if len(l.split()) >= 2 and l.split()[1] == "device"]

def get_current_ssid():
    try:
        r = subprocess.run(["nmcli", "-t", "-f", "active,ssid", "dev", "wifi"],
                           capture_output=True, text=True, timeout=5)
        for line in r.stdout.splitlines():
            if line.startswith("yes:"):
                return line.split(":", 1)[1].strip()
    except Exception:
        pass
    return None

_scrcpy_ver_cache = None

def get_scrcpy_version():
    """Return (major, minor) tuple, e.g. (2, 3). Returns (0, 0) if unknown.
    Result is cached after the first call so subsequent calls are instant."""
    global _scrcpy_ver_cache
    if _scrcpy_ver_cache is not None:
        return _scrcpy_ver_cache
    try:
        r = subprocess.run(["scrcpy", "--version"], capture_output=True, text=True, timeout=5)
        m = re.search(r"scrcpy\s+(\d+)\.(\d+)", (r.stdout + r.stderr))
        if m:
            _scrcpy_ver_cache = (int(m.group(1)), int(m.group(2)))
            return _scrcpy_ver_cache
    except Exception:
        pass
    _scrcpy_ver_cache = (0, 0)
    return _scrcpy_ver_cache

def check_dependencies():
    """Returns list of missing/broken dependency descriptions."""
    issues = []
    # Check adb
    out, err, rc = run("adb", "version")
    if rc != 0 or "Android Debug Bridge" not in out:
        issues.append("adb not found — install android-tools")
    # Check scrcpy
    maj, _ = get_scrcpy_version()
    if maj == 0:
        issues.append("scrcpy not found — install scrcpy")
    elif maj < 2:
        issues.append(f"scrcpy is too old (need 2.x, have 1.x) — upgrade scrcpy")
    return issues

def build_scrcpy_args(settings):
    s = {**DEFAULT_SETTINGS, **settings}
    maj, _ = get_scrcpy_version()

    if maj >= 2:
        # scrcpy 2.x flags
        args = [
            "--video-bit-rate", s["bitrate"],
            "--max-fps", str(s["max_fps"]),
            "--max-size", str(s["resolution"]),
            "--video-buffer=0",
            "--video-codec", s["codec"],
            "--capture-orientation=0",
        ]
        if s["turn_off_screen"]:
            args.append("--turn-screen-off")
        if s["stay_awake"]:
            args.append("--stay-awake")
    else:
        # scrcpy 1.x fallback flags
        args = [
            "--bit-rate", s["bitrate"],
            "--max-fps", str(s["max_fps"]),
            "--max-size", str(s["resolution"]),
        ]
        if s["turn_off_screen"]:
            args.append("--turn-screen-off")
        if s["stay_awake"]:
            args.append("--stay-awake")
    return args

