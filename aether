        self._refresh_home()
        self.stack.set_visible_child_name(PAGE_HOME)
        if self.mirror_dev is None:
            self._mirror_btn.set_label("SELECT A DEVICE")
            self._mirror_btn.set_sensitive(False)

    def _set_dot(self, state):
        for c in ["dot-off","dot-on","dot-busy"]: self._dot.remove_css_class(c)
        self._dot.add_css_class({"off":"dot-off","on":"dot-on","busy":"dot-busy"}[state])


class AetherApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="io.github.aether",
                         flags=Gio.ApplicationFlags.FLAGS_NONE)
        self.connect("activate", self._on_activate)

    def _on_activate(self, _):
        win = AetherWindow(self)
        win.set_icon_name("aether")
        win.present()

if __name__ == "__main__":
    import sys
    AetherApp().run(sys.argv)
