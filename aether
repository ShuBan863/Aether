    def _to_add(self):
        for w in [self._pair_name, self._pair_ip, self._pair_code, self._conn_ip]:
            w.set_text("")
        self._pair_status.set_label(""); self._conn_status.set_label("")
        self._add_title.set_label("PAIR DEVICE")
        self._add_sub.set_visible_child_name("pair")
        self.stack.set_visible_child_name(PAGE_ADD)

    def _do_pair(self, _):
        name = self._pair_name.get_text().strip()
        pip  = self._pair_ip.get_text().strip()
        code = self._pair_code.get_text().strip()
        if not name: self._set_ps("Enter a device name.", "err"); return
        if not pip or ":" not in pip: self._set_ps("Enter the pairing IP:PORT.", "err"); return
        if len(code) < 6: self._set_ps("Enter the 6-digit pairing code.", "err"); return
        self._pair_btn.set_sensitive(False); self._pair_spinner.start()
        self._set_ps("Pairing…", "lbl")
        threading.Thread(target=self._pair_worker, args=(pip, code, name), daemon=True).start()

    def _pair_worker(self, pip, code, name):
        ok = adb_pair(pip, code)
        GLib.idle_add(self._pair_done, ok, name, pip)

    def _pair_done(self, ok, name, pip):
        self._pair_spinner.stop(); self._pair_btn.set_sensitive(True)
        if ok:
            self._set_ps("✓  Paired!", "ok")
            self._conn_ip.set_text(pip.split(":")[0] + ":")
            self._pending_name = name
            GLib.timeout_add(600, self._go_connect)
        else:
            self._set_ps("✗  Failed. Check code and try again.", "err")

    def _go_connect(self):
        self._add_title.set_label("CONNECT")
        self._add_sub.set_visible_child_name("connect")
        return False

    def _do_connect(self, _):
        ip = self._conn_ip.get_text().strip()
        nm = self._pending_name or self._pair_name.get_text().strip() or "Android Device"
        if not ip or ":" not in ip or ip.endswith(":"):
            self._set_cs("Enter a valid IP:PORT.", "err"); return
        self._conn_btn.set_sensitive(False); self._conn_spinner.start()
        self._set_cs("Connecting…", "lbl")
        threading.Thread(target=self._connect_worker, args=(nm, ip), daemon=True).start()

    def _connect_worker(self, name, ip_port):
        adb_start()
        ok = adb_connect(ip_port, timeout=8)
        GLib.idle_add(self._connect_done, ok, name, ip_port)

    def _connect_done(self, ok, name, ip_port):
        self._conn_spinner.stop(); self._conn_btn.set_sensitive(True)
        if ok:
            self._save_device(name, ip_port); self._to_home()
        else:
            self._set_cs("Could not connect.\nMake sure Wireless Debugging is ON.", "err")

    def _save_device(self, name, ip_port):
        ssid = self._ssid_cache
        devs = self.config.setdefault("devices", [])
        for dev in devs:
            if dev.get("name") == name:
                dev["last_ip_port"] = ip_port
                if ssid: dev.setdefault("networks",{})[ssid] = ip_port
                save_config(self.config); return
        devs.append({
            "name": name, "last_ip_port": ip_port,
            "networks": {ssid: ip_port} if ssid else {},
            "settings": dict(DEFAULT_SETTINGS),
        })
        save_config(self.config)

    def _set_ps(self, msg, kind):
