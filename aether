        for c in ["status-lbl","status-err","status-ok"]:
            self._pair_status.remove_css_class(c)
        self._pair_status.add_css_class(f"status-{kind}")

    def _set_cs(self, msg, kind):
        self._conn_status.set_label(msg)
        for c in ["status-lbl","status-err","status-ok"]:
            self._conn_status.remove_css_class(c)
        self._conn_status.add_css_class(f"status-{kind}")

