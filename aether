    def _to_home(self):
        self._refresh_home()
        self.stack.set_visible_child_name(PAGE_HOME)
        if self.mirror_dev is None:
            self._mirror_btn.set_label("SELECT A DEVICE")
            self._mirror_btn.set_sensitive(False)

    def _set_dot(self, state):
        for c in ["dot-off","dot-on","dot-busy"]: self._dot.remove_css_class(c)
        self._dot.add_css_class({"off":"dot-off","on":"dot-on","busy":"dot-busy"}[state])


class AetherApp(Adw.Application):
    def __init__(self):
        super().__init__(
            application_id="io.github.aether",
            flags=Gio.ApplicationFlags.FLAGS_NONE,
        )
        self.connect("activate", self._on_activate)
        self._win = None

    def _on_activate(self, _):
        if self._win is not None:
            self._win.present()
            return
        win = AetherWindow(self)
        self._win = win
        win.set_icon_name("aether")
        win.present()


def _install_mirror_icon():
    """Write aether-mirror.desktop so GNOME Shell maps WM_CLASS=aether-mirror
    to phone.png.  Uses absolute Icon= path — no icon theme cache needed.
    Runs synchronously before AetherApp.run() so the file exists before any
    mirror session starts."""
    try:
        phone_src = AETHER_DIR / "phone.png"
        if not phone_src.exists():
            return
        apps_dir = Path.home() / ".local/share/applications"
        apps_dir.mkdir(parents=True, exist_ok=True)
        (apps_dir / "aether-mirror.desktop").write_text(
            "[Desktop Entry]\n"
            "Name=Aether Mirror\n"
            "Exec=false\n"
            f"Icon={phone_src.resolve()}\n"
            "Terminal=false\n"
            "Type=Application\n"
            "NoDisplay=true\n"
            "StartupWMClass=aether-mirror\n"
        )
        subprocess.run(
            ["update-desktop-database", str(apps_dir)],
            capture_output=True)
    except Exception:
        pass


if __name__ == "__main__":
    import sys
    _install_mirror_icon()
    AetherApp().run(sys.argv)
