    def _toggle_advanced(self, _):
        visible = not self._adv_box.get_visible()
        self._adv_box.set_visible(visible)
        self._adv_arrow.set_label(
            "▼  ADVANCED SETTINGS" if visible else "▶  ADVANCED SETTINGS")

    def _open_settings(self, idx):
        self._set_idx = idx
        devs = self.config.get("devices",[])
        if idx >= len(devs): return
        dev = devs[idx]; s = {**DEFAULT_SETTINGS, **dev.get("settings",{})}
        self._set_title.set_label(dev.get("name","").upper() + " SETTINGS")
        self._set_name.set_text(dev.get("name",""))
        ssid = self._ssid_cache
        ip   = dev.get("networks",{}).get(ssid) or dev.get("last_ip_port","")
        self._set_ip.set_text(ip)
        self._set_net_hint.set_label(f"Network: {ssid}" if ssid else "No WiFi detected")

        res_opts=[480,720,1080,1440,2160]; res_val=s.get("resolution",1080)
        self._res_combo.set_selected(res_opts.index(res_val) if res_val in res_opts else 2)

        self._fps_spin.set_value(s["max_fps"])
        br_opts=["4M","8M","12M","16M","24M","32M"]
        self._br_combo.set_selected(br_opts.index(s["bitrate"]) if s["bitrate"] in br_opts else 3)
        co_opts=["h264","h265"]
        self._codec_combo.set_selected(co_opts.index(s["codec"]) if s["codec"] in co_opts else 0)
        self._sw_screen.set_active(s["turn_off_screen"])
        self._sw_awake.set_active(s["stay_awake"])

        # collapse advanced on open
        self._adv_box.set_visible(False)
        self._adv_arrow.set_label("▶  ADVANCED SETTINGS")

        self.stack.set_visible_child_name(PAGE_SETTINGS)

    def _save_settings(self, _):
        if self._set_idx is None: return
        devs = self.config.get("devices",[])
        if self._set_idx >= len(devs): return
        dev = devs[self._set_idx]
        name=self._set_name.get_text().strip() or dev.get("name","Device")
        ip  =self._set_ip.get_text().strip()
        ssid=self._ssid_cache
        dev["name"]=name
        if ip and ":" in ip:
            dev["last_ip_port"]=ip
            if ssid: dev.setdefault("networks",{})[ssid]=ip
        res_opts=[480,720,1080,1440,2160]
        br_opts=["4M","8M","12M","16M","24M","32M"]
        co_opts=["h264","h265"]
        dev["settings"]={
            "resolution":      res_opts[self._res_combo.get_selected()],
            "max_fps":         int(self._fps_spin.get_value()),
            "bitrate":         br_opts[self._br_combo.get_selected()],
            "codec":           co_opts[self._codec_combo.get_selected()],
            "turn_off_screen": self._sw_screen.get_active(),
            "stay_awake":      self._sw_awake.get_active(),
        }
        save_config(self.config); self._to_home()

    def _delete_device(self, _):
        if self._set_idx is None: return
        devs = self.config.get("devices",[])
        if self._set_idx < len(devs):
            dev = devs[self._set_idx]
            ssid = self._ssid_cache
            ip   = dev.get("networks",{}).get(ssid) or dev.get("last_ip_port","")
            if ip:
                threading.Thread(target=adb_disconnect, args=(ip,), daemon=True).start()
            devs.pop(self._set_idx)
            save_config(self.config)
        self.selected_idx = None
        self._to_home()
        dlg = Adw.MessageDialog(transient_for=self, modal=True)
        dlg.set_heading("Device Removed")
        dlg.set_body(
            "Removed from Aether and ADB disconnected.\n\n"
            "To fully unpair on the phone:\n"
            "Settings → Developer options → Wireless debugging\n"
            "→ Paired devices → remove this computer."
        )
        dlg.add_response("ok","OK"); dlg.present()

